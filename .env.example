# ─── Database ───
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=wallet_service
PG_USER=postgres
PG_PASSWORD=change-me
# یا:
# DATABASE_URL=postgres://user:pass@localhost:5432/wallet_service

# ─── Redis (برای BullMQ و cache) ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Encryption ───
# تولید:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WALLET_MASTER_KEY=

# ─── Auth ───
JWT_SECRET=
COOKIE_SECRET=

# ─── Server ───
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Workers ───
GEN_CONCURRENCY=2
BALANCE_CONCURRENCY=3

# ─── Balance API endpoints (default‌ها خوبن، rarely need to change) ───
# BTC_API=https://mempool.space/api
# ETH_RPC=https://eth.llamarpc.com
# TRON_API=https://api.trongrid.io

# TronGrid API keys (اختیاری ولی توصیه می‌شه)
# بدون کلید: ۱۵ req/sec
# با یه کلید: ۱۰۰ req/sec
# با چند کلید (کاما جدا): ۱۰۰ × تعداد
# از https://www.trongrid.io بگیر رایگانه
# TRONGRID_API_KEYS=key1,key2,key3
# یا فقط یکی:
# TRONGRID_API_KEY=
